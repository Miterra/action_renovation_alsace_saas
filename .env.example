# =======================================================
# Action Rénovation Alsace - SaaS - Variables d'environnement
# =======================================================
# Copier ce fichier en `.env.local` puis remplir les valeurs.
# Aucun secret ne doit être commit sur Git.

# ---- Firebase (Firestore + Cloud Messaging) ----
# Console : https://console.firebase.google.com/
VITE_FIREBASE_API_KEY=__REMPLACER_API_KEY__
VITE_FIREBASE_AUTH_DOMAIN=__REMPLACER_PROJECT__.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=__REMPLACER_PROJECT_ID__
VITE_FIREBASE_STORAGE_BUCKET=__REMPLACER_PROJECT__.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=__REMPLACER_SENDER_ID__
VITE_FIREBASE_APP_ID=__REMPLACER_APP_ID__

# Clé VAPID publique pour la Web Push API (FCM > Paramètres > Cloud Messaging)
VITE_FIREBASE_VAPID_KEY=__REMPLACER_VAPID_PUBLIC_KEY__

# ---- Google OAuth 2.0 (Gmail API - action.renovation67@gmail.com) ----
# Console : https://console.cloud.google.com/apis/credentials
# Scope nécessaire : https://www.googleapis.com/auth/gmail.readonly
VITE_GOOGLE_CLIENT_ID=__REMPLACER_CLIENT_ID__.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=__REMPLACER_GOOGLE_API_KEY__

# Compte cible (informationnel - le user choisit son compte au sign-in)
VITE_GMAIL_ACCOUNT=action.renovation67@gmail.com
